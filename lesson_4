#Excersise:2
import math
a=4
b=5
def power(a, b):
    return math.pow(a, b)
print(power(a, b))
def factorial(a):
    return math.factorial(a)
print(factorial(a))
def ceil(a):
    return math.ceil(a)
print(ceil(a))#rounds up to the nearest integer
def floor(a):
    return math.floor(a)
print(floor(a))#rounds down to the nearest integer




